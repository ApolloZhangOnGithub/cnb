#!/usr/bin/env bash
set -euo pipefail

CLAUDES_HOME="$(cd "$(dirname "$0")/.." && pwd)"
VERSION=$(cat "$CLAUDES_HOME/VERSION" 2>/dev/null || echo "dev")

# ---- ANSI (TTY only) ----
if [ -t 1 ] || [ -t 2 ]; then
    B=$'\033[1m' D=$'\033[2m' G=$'\033[0;32m' C=$'\033[0;36m' Y=$'\033[1;33m' N=$'\033[0m'
else
    B='' D='' G='' C='' Y='' N=''
fi

# ---- default: show dashboard ----
if [ $# -eq 0 ]; then
    if [ -f .claudes/board.db ]; then
        exec "$CLAUDES_HOME/bin/board" overview
    else
        printf '%s%sclaudes-code%s %sv%s%s\n\n' "$B" "$G" "$N" "$D" "$VERSION" "$N"
        echo "Not initialized. Get started:"
        echo
        printf '  claudes-code %sinit%s alice bob charlie\n' "$C" "$N"
        echo
        echo "Or: claudes-code help"
    fi
    exit 0
fi

cmd="$1"; shift

case "$cmd" in
    init)       exec "$CLAUDES_HOME/bin/init" "$@" ;;
    board)      exec "$CLAUDES_HOME/bin/board" "$@" ;;
    swarm)      exec "$CLAUDES_HOME/bin/swarm" "$@" ;;
    dispatcher) exec "$CLAUDES_HOME/bin/dispatcher" "$@" ;;
    watchdog)   exec "$CLAUDES_HOME/bin/dispatcher-watchdog" "$@" ;;
    doctor)     exec "$CLAUDES_HOME/bin/doctor" "$@" ;;
    version|--version|-v) echo "claudes-code v${VERSION}" ;;
    help|--help|-h)
        printf '%s%sclaudes-code%s %sv%s%s  —  multi-agent coordination for Claude Code\n\n' "$B" "$G" "$N" "$D" "$VERSION" "$N"
        printf '%sUsage:%s  claudes-code %s<command>%s [args...]\n\n' "$B" "$N" "$C" "$N"
        printf '%sCommands:%s\n' "$B" "$N"
        printf '  %sinit%s      <names...>   Initialize a project for multi-agent work\n' "$C" "$N"
        printf '  %sboard%s     [args...]    Send messages, manage tasks/bugs, vote on proposals\n' "$C" "$N"
        printf '  %sswarm%s     [args...]    Start, stop, or attach to agent sessions\n' "$C" "$N"
        printf '  %sdispatcher%s             Run the session keepalive + health monitor daemon\n' "$C" "$N"
        printf '  %swatchdog%s              Run dispatcher with automatic restart on crash\n' "$C" "$N"
        printf '  %sdoctor%s                System health check (environment, DB, config, sessions)\n' "$C" "$N"
        printf '\n%sWithout arguments, shows the team dashboard.%s\n' "$D" "$N"
        printf '%sRun "claudes-code <command> --help" for detailed usage.%s\n' "$D" "$N"
        ;;
    *)
        printf '%sUnknown command:%s %s\n' "$Y" "$N" "$cmd" >&2
        echo "Run 'claudes-code help' for available commands." >&2
        exit 1
        ;;
esac
