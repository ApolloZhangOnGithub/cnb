#!/usr/bin/env bash
set -euo pipefail

CLAUDES_HOME="$(cd "$(dirname "$0")/.." && pwd)"
VERSION=$(cat "$CLAUDES_HOME/VERSION" 2>/dev/null || echo "dev")

if [ -t 1 ] || [ -t 2 ]; then
    B=$'\033[1m' D=$'\033[2m' G=$'\033[0;32m' Y=$'\033[1;33m' N=$'\033[0m'
else
    B='' D='' G='' Y='' N=''
fi

# ---- Version update check (non-blocking, user-facing only at interactive startup) ----
_CACHE="$HOME/.cnb/latest-version"
_NOTIFIED="$HOME/.cnb/update-notified"
_in_virtualenv() {
    [ -n "${VIRTUAL_ENV:-}" ] && return 0
    command -v python3 >/dev/null 2>&1 || return 1
    python3 - <<'PY'
import sys
raise SystemExit(0 if sys.prefix != sys.base_prefix else 1)
PY
}

_read_update_owner() {
    if [ -n "${CNB_UPDATE_OWNER:-}" ]; then
        printf '%s\n' "$CNB_UPDATE_OWNER"
        return 0
    fi

    local global_cfg="$HOME/.cnb/config.toml"
    if [ -f "$global_cfg" ]; then
        local global_owner
        global_owner="$(python3 - "$global_cfg" <<'PY'
import sys
import tomllib
from pathlib import Path

try:
    data = tomllib.loads(Path(sys.argv[1]).read_text())
except Exception:
    raise SystemExit(0)

for key in ("update_owner", "cnb_owner", "maintainer", "owner"):
    value = data.get(key)
    if isinstance(value, str) and value.strip():
        print(value.strip())
        raise SystemExit(0)

cnb = data.get("cnb")
if isinstance(cnb, dict):
    for key in ("update_owner", "owner", "maintainer"):
        value = cnb.get(key)
        if isinstance(value, str) and value.strip():
            print(value.strip())
            raise SystemExit(0)
PY
)"
        if [ -n "$global_owner" ]; then
            printf '%s\n' "$global_owner"
            return 0
        fi
    fi

    local project_cfg="$CNB_PROJECT/.cnb/config.toml"
    [ ! -f "$project_cfg" ] && project_cfg="$CNB_PROJECT/.claudes/config.toml"
    [ -f "$project_cfg" ] || return 0
    python3 - "$project_cfg" <<'PY'
import sys
import tomllib
from pathlib import Path

try:
    data = tomllib.loads(Path(sys.argv[1]).read_text())
except Exception:
    raise SystemExit(0)

sessions = data.get("session")
if isinstance(sessions, dict):
    for name, meta in sessions.items():
        if isinstance(meta, dict) and meta.get("role") == "lead":
            print(name)
            raise SystemExit(0)

names = data.get("sessions")
if isinstance(names, list):
    if "lead" in names:
        print("lead")
        raise SystemExit(0)
    for name in names:
        if isinstance(name, str) and name:
            print(name)
            raise SystemExit(0)
PY
}

_notify_update_owner() {
    local latest="$1"
    local current="$2"
    local owner
    owner="$(_read_update_owner 2>/dev/null | head -n 1 || true)"
    [ -n "$owner" ] || return 0
    [ -f "$CNB_PROJECT/.cnb/board.db" ] || [ -f "$CNB_PROJECT/.claudes/board.db" ] || return 0

    local key="${owner}:${current}->${latest}"
    if [ -f "$_NOTIFIED" ] && [ "$(cat "$_NOTIFIED" 2>/dev/null || true)" = "$key" ]; then
        return 0
    fi

    local msg="[cnb update] cnb v${latest} 已发布，当前 v${current}。请由本机 cnb 负责人执行：npm install -g claude-nb"
    if CNB_PROJECT="$CNB_PROJECT" "$CLAUDES_HOME/bin/board" --as dispatcher send "$owner" "$msg" >/dev/null 2>&1; then
        printf '%s\n' "$key" > "$_NOTIFIED"
    fi
}

_version_gt() {
    command -v python3 >/dev/null 2>&1 || return 1
    python3 - "$1" "$2" <<'PY'
import re
import sys


def normalize(version: str) -> tuple[int, ...]:
    version = version.strip().lstrip("vV")
    version = re.sub(r"\.dev\d*$", "", version)
    version = re.sub(r"[-+].*$", "", version)
    parts = []
    for part in version.split("."):
        match = re.match(r"\d+", part)
        parts.append(int(match.group(0)) if match else 0)
    return tuple(parts + [0] * (4 - len(parts)))


raise SystemExit(0 if normalize(sys.argv[1]) > normalize(sys.argv[2]) else 1)
PY
}

_check_update() {
    local mode="${1:-interactive}"
    _in_virtualenv && return 0

    mkdir -p "$HOME/.cnb"
    if [ ! -f "$_CACHE" ] || [ "$(find "$_CACHE" -mmin +60 2>/dev/null)" ]; then
        (npm view claude-nb version 2>/dev/null > "$_CACHE.tmp" && mv "$_CACHE.tmp" "$_CACHE" || rm -f "$_CACHE.tmp") &
    fi
    if [ -f "$_CACHE" ]; then
        local latest
        local current
        latest=$(cat "$_CACHE" 2>/dev/null | tr -d '[:space:]')
        current=$(echo "$VERSION" | sed -E 's/-dev$//; s/\.dev[0-9]+$//')
        if [ -n "$latest" ] && _version_gt "$latest" "$current"; then
            if [ "$mode" = "notify" ]; then
                _notify_update_owner "$latest" "$VERSION"
            else
                printf "${Y}⬆ cnb v${latest} 已发布，当前 v${VERSION}。运行 npm install -g claude-nb 更新。${N}\n"
            fi
        fi
    fi
}

# ---- Export project root so all subprocesses can find .cnb/ ----
export CNB_PROJECT="${CNB_PROJECT:-$(pwd)}"

if [ $# -gt 0 ]; then
    _check_update notify
fi

# ---- Subcommands (exact match, always first) ----
if [ $# -gt 0 ]; then
    case "$1" in
        init)       shift; exec "$CLAUDES_HOME/bin/init" "$@" ;;
        status|ps)  exec "$CLAUDES_HOME/bin/board" overview ;;
        board)      shift; exec "$CLAUDES_HOME/bin/board" "$@" ;;
        model|m)    shift; exec "$CLAUDES_HOME/bin/board" model "$@" ;;
        swarm)      shift; exec "$CLAUDES_HOME/bin/swarm" "$@" ;;
        dispatcher) shift; exec "$CLAUDES_HOME/bin/dispatcher" "$@" ;;
        watchdog)   shift; exec "$CLAUDES_HOME/bin/dispatcher-watchdog" "$@" ;;
        doctor)     shift; exec "$CLAUDES_HOME/bin/doctor" "$@" ;;
        hygiene)    shift; exec "$CLAUDES_HOME/bin/hygiene" "$@" ;;
        resources|resource) shift; PYTHONPATH="$CLAUDES_HOME${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m lib.resources "$@" ;;
        checkpoint) shift; exec "$CLAUDES_HOME/bin/checkpoint" "$@" ;;
        feishu)     shift; PYTHONPATH="$CLAUDES_HOME${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m lib.feishu_bridge "$@" ;;
        feishu-chief)
            shift
            PYTHONPATH="$CLAUDES_HOME${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m lib.feishu_bridge --config "$HOME/.cnb/device-chief/config.toml" "$@" ;;
        capture)    shift; PYTHONPATH="$CLAUDES_HOME${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m lib.capture_ingest "$@" ;;
        shutdown)   shift; exec "$CLAUDES_HOME/bin/shutdown" "$@" ;;
        logs)
            shift
            if [ $# -eq 0 ]; then
                echo "用法: cnb logs <name>" >&2; exit 1
            fi
            exec "$CLAUDES_HOME/bin/board" --as "$1" log 50 ;;
        stop)
            shift
            if [ $# -eq 0 ]; then
                echo "用法: cnb stop <name>" >&2; exit 1
            fi
            exec "$CLAUDES_HOME/bin/swarm" stop "$@" ;;
        exec)
            shift
            if [ $# -lt 2 ]; then
                echo "用法: cnb exec <name> \"message\"" >&2; exit 1
            fi
            _target="$1"; shift
            _sender="${CNB_EXEC_FROM:-}"
            if [ -z "$_sender" ]; then
                _sender="$(_read_update_owner 2>/dev/null | head -n 1 || true)"
            fi
            [ -n "$_sender" ] || _sender="dispatcher"
            exec "$CLAUDES_HOME/bin/board" --as "$_sender" send "$_target" "$*" ;;
        compose)
            shift
            _TEAM_FILE="${1:-cnb.toml}"
            if [ ! -f "$_TEAM_FILE" ]; then
                echo "错误: 找不到团队配置文件 '$_TEAM_FILE'" >&2
                echo "用法: cnb compose [team-file.toml]" >&2
                echo "" >&2
                echo "示例 cnb.toml:" >&2
                echo '  [session.alice]' >&2
                echo '  persona = "Backend engineer"' >&2
                echo '  [session.bob]' >&2
                echo '  persona = "Frontend specialist"' >&2
                exit 1
            fi
            "$CLAUDES_HOME/bin/init" --team "$_TEAM_FILE"
            _NAMES=$(python3 -c "
import tomllib, sys
data = tomllib.loads(open(sys.argv[1]).read())
names = list(data.get('session', {}).keys())
print(' '.join(names))
" "$_TEAM_FILE")
            if [ -n "$_NAMES" ]; then
                "$CLAUDES_HOME/bin/swarm" start $_NAMES >/dev/null 2>&1 || true
                echo "OK 团队已启动: $_NAMES"
            fi
            exit 0 ;;
        projects)
            shift
            if [ $# -eq 0 ]; then
                echo "用法: cnb projects <list|cleanup|scan>" >&2; exit 1
            fi
            subcmd="$1"; shift
            case "$subcmd" in
                list)
                    python3 -c "
import sys; sys.path.insert(0, '$CLAUDES_HOME')
from lib.global_registry import list_projects
projects = list_projects()
if not projects:
    print('没有已注册的项目')
else:
    for p in projects:
        print(f\"  {p['name']:20s} {p['path']}  (最后活跃: {p.get('last_active', '未知')})\")
" ;;
                cleanup)
                    python3 -c "
import sys; sys.path.insert(0, '$CLAUDES_HOME')
from lib.global_registry import cleanup
removed = cleanup()
if not removed:
    print('没有需要清理的项目')
else:
    for p in removed:
        print(f'  已移除: {p}')
    print(f'OK 清理了 {len(removed)} 个失效项目')
" ;;
                scan)
                    python3 - "$@" <<PY
import sys; sys.path.insert(0, '$CLAUDES_HOME')
from lib.global_registry import cmd_projects_scan
cmd_projects_scan(sys.argv[1:])
PY
                    ;;
                *)
                    echo "用法: cnb projects <list|cleanup|scan>" >&2; exit 1 ;;
            esac
            exit 0 ;;
        ui)         shift; exec "$CLAUDES_HOME/bin/board" tui ;;
        usage)
            shift
            python3 -c "
import sys; sys.path.insert(0, '$CLAUDES_HOME')
from pathlib import Path
from lib.token_usage import cmd_usage
cmd_usage(Path('$CNB_PROJECT'), sys.argv[1:])
" "$@"
            exit 0 ;;
        leaderboard)
            echo "${B}${G}◆ 贡献排行榜${N}"
            echo ""
            git -C "$CNB_PROJECT" log --format='%aN%n%(trailers:key=Co-Authored-By,valueonly,separator=%x0A)' \
                | sed '/^$/d' | sed 's/^ *//' | sed 's/ *<[^>]*>//g' \
                | sort | uniq -c | sort -rn \
                | awk -v b="$B" -v n="$N" -v g="$G" -v y="$Y" '{
                    rank++
                    if (rank == 1) medal = "🥇"
                    else if (rank == 2) medal = "🥈"
                    else if (rank == 3) medal = "🥉"
                    else medal = "  "
                    name = ""
                    for (i = 2; i <= NF; i++) name = name (i > 2 ? " " : "") $i
                    printf "  %s %s%-20s%s %s%d commits%s\n", medal, b, name, n, g, $1, n
                }'
            exit 0 ;;
        version|--version|-v) echo "cnb v${VERSION}"; exit 0 ;;
        help|--help|-h)
            printf "${B}${G}◆ cnb${N} ${D}v${VERSION}${N}\n"
            printf "  多个 Claude Code / Codex 实例协作的团队开发工具\n\n"
            printf "  cnb                   开始（默认2位同学，AI大佬主题，Claude）\n"
            printf "  cnb codex             使用 Codex 作为领队和后台同学引擎\n"
            printf "  cnb --agent codex 5   5位同学 + Codex 引擎\n"
            printf "  cnb 5                 5位同学\n"
            printf "  cnb threebody         三体主题\n"
            printf "  cnb 5 titan           5位同学 + 科技先锋主题\n"
            printf "  cnb compose [file]    从配置文件启动团队\n\n"
            printf "  主题: ai animal food lang music myth space threebody titan\n\n"
            printf "  cnb ui                交互式团队面板\n"
            printf "  cnb ps                列出同学状态\n"
            printf "  cnb logs <name>       查看某个同学的消息历史\n"
            printf "  cnb exec <name> \"msg\" 给某个同学发指令\n"
            printf "  cnb stop <name>       停止某个同学\n"
            printf "  cnb projects list     列出所有已注册的项目\n"
            printf "  cnb projects scan     扫描本机真实 cnb 项目\n"
            printf "  cnb projects cleanup  清理已失效的项目\n"
            printf "  cnb usage             token 用量统计\n"
            printf "  cnb leaderboard       贡献排行榜\n"
            printf "  cnb doctor            健康检查\n\n"
            printf "  cnb hygiene           区分可清缓存、本地状态、疑似备份\n\n"
            printf "  cnb resources --processes  只读查看 Mac 资源压力和高占用进程分组\n\n"
            printf "  cnb checkpoint        关停/迁移/交接前检查脏工作区和秘密风险\n\n"
            printf "  cnb feishu status     查看飞书入站 bridge 配置\n"
            printf "  cnb feishu setup      自动写配置、启动 webhook、准备公网回调\n"
            printf "  cnb feishu start      启动飞书入站 bridge，允许用户从飞书唤起本机设备主管同学\n\n"
            printf "  cnb feishu-chief status  查看机器总管独立飞书 bridge 配置\n"
            printf "  cnb feishu-chief start   启动机器总管独立飞书 bridge\n\n"
            printf "  cnb feishu activity   查看设备/tmux/团队/前台会话活动摘要\n"
            printf "  cnb feishu tui        查看设备主管 TUI 快照\n"
            printf "  cnb feishu watch      启动只读 Web TUI\n\n"
            printf "  cnb capture ingest    接收用户授权的网页/应用 capture\n"
            printf "  cnb capture list      列出本项目 capture\n"
            printf "  cnb capture show <id> 查看 capture 内容\n\n"
            printf "  cnb board [...]       底层消息/任务命令\n"
            printf "  cnb swarm [...]       管理后台同学\n"
            exit 0 ;;
    esac
fi

# ---- Lead engine selection ----
# Claude remains the default. Codex can be selected with either:
#   CNB_AGENT=codex cnb
#   cnb codex
#   cnb --agent codex
_LEAD_AGENT="${CNB_AGENT:-claude}"
if [ -z "${CNB_AGENT:-}" ] && [ "${SWARM_AGENT:-}" = "codex" ]; then
    _LEAD_AGENT="codex"
fi
_ARGS=()
while [ $# -gt 0 ]; do
    case "$1" in
        --agent=*)
            _LEAD_AGENT="${1#--agent=}"
            shift ;;
        --agent)
            shift
            if [ $# -eq 0 ]; then
                echo "错误: --agent 需要参数: claude 或 codex" >&2
                exit 1
            fi
            _LEAD_AGENT="$1"
            shift ;;
        claude|codex)
            _LEAD_AGENT="$1"
            shift ;;
        *)
            _ARGS+=("$1")
            shift ;;
    esac
done
if [ "${#_ARGS[@]}" -gt 0 ]; then
    set -- "${_ARGS[@]}"
else
    set --
fi

case "$_LEAD_AGENT" in
    claude|codex) ;;
    *)
        echo "错误: 不支持的领队引擎: $_LEAD_AGENT" >&2
        echo "可选: claude, codex" >&2
        exit 1 ;;
esac
export CNB_AGENT="$_LEAD_AGENT"
export SWARM_AGENT="${SWARM_AGENT:-$_LEAD_AGENT}"

# ---- Helper: start dispatcher if not already running ----
_start_dispatcher() {
    case "${CNB_AUTO_DISPATCHER:-1}" in
        0|false|False|no|No|off|Off) return ;;
    esac
    local pidfile="$CNB_PROJECT/$_CFG_DIR/dispatcher-watchdog.pid"
    if [ -f "$pidfile" ] && kill -0 "$(cat "$pidfile")" 2>/dev/null; then
        return
    fi
    mkdir -p "$CNB_PROJECT/$_CFG_DIR/logs"
    "$CLAUDES_HOME/bin/dispatcher-watchdog" >> "$CNB_PROJECT/$_CFG_DIR/logs/dispatcher-watchdog.log" 2>&1 &
    echo $! > "$pidfile"
    disown
}

# ---- Compose mode: reuse existing team from config.toml ----
# Detect config dir: prefer .cnb/, fall back to .claudes/
_CFG_DIR=".cnb"
[ ! -f ".cnb/config.toml" ] && [ -f ".claudes/config.toml" ] && _CFG_DIR=".claudes"

if [ -f "$_CFG_DIR/config.toml" ] && [ -f "$_CFG_DIR/board.db" ]; then
    _EXISTING=$(grep '^sessions' "$_CFG_DIR/config.toml" | sed 's/sessions = \[//;s/\]//;s/"//g;s/,/ /g;s/  */ /g' | xargs)
    if [ -n "$_EXISTING" ]; then
        ME=$(echo "$_EXISTING" | cut -d' ' -f1)
        WORKERS=$(echo "$_EXISTING" | cut -d' ' -f2-)
        LABEL=$(grep '^prefix' "$_CFG_DIR/config.toml" | cut -d'"' -f2)
        _NUM=$(echo "$WORKERS" | wc -w | tr -d ' ')
        "$CLAUDES_HOME/bin/swarm" start $WORKERS >/dev/null 2>&1 &
        disown
        _start_dispatcher
    fi
else
    # ---- Fresh start: parse [number] [theme] in any order ----
    _NUM=2
    _THEME_IDX=6  # default: AI 大佬

    _THEME_MAP="ai:6 animal:0 food:2 lang:1 music:5 myth:4 space:3 threebody:7 titan:8"

    for arg in "$@"; do
        if [[ "$arg" =~ ^[0-9]+$ ]]; then
            _NUM="$arg"
        else
            _idx=$(echo "$_THEME_MAP" | tr ' ' '\n' | grep "^${arg}:" | cut -d: -f2 || true)
            if [ -n "$_idx" ]; then
                _THEME_IDX="$_idx"
            else
                printf "${Y}未知参数: ${arg}${N}\n" >&2
                echo "用法: cnb [数量] [主题] [claude|codex]" >&2
                echo "主题: ai animal food lang music myth space threebody titan" >&2
                exit 1
            fi
        fi
    done

    # ---- Theme data ----
    _THEMES=(
        "panda otter fox raccoon bunny koala sloth penguin hamster hedgehog duck seal capybara alpaca corgi shiba husky kitten ferret quokka"
        "python ruby rust go swift kotlin scala perl haskell erlang elixir clojure julia ocaml zig lua dart cobol lisp fortran"
        "mochi waffle taco ramen sushi bagel pretzel dumpling cookie brownie churro crepe noodle tofu falafel burrito pancake donut nacho boba"
        "nebula pulsar quasar comet aurora meteor nova orbit cosmos galaxy venus mars saturn pluto titan europa io ceres vega sirius"
        "dragon phoenix griffin hydra kraken sphinx unicorn pixie goblin imp djinn yeti nymph chimera basilisk manticore cerberus minotaur golem banshee"
        "jazz blues funk reggae disco punk grunge techno dubstep waltz tango salsa bossa swing opera gospel motown bebop ska hiphop"
        "altman dario ilya lecun karpathy hassabis vaswani hinton bengio fei-fei ng zuck bezos nadella pichai musk huang lisa-su radford jack-clark"
        "luo-ji shi-qiang ye-wenjie cheng-xin zhang-beihai yun-tianming wang-miao ding-yi yang-dong zhuang-yan guan-yifan shen-yufei wei-cheng hines tyler wade evans rey-diaz tomoko singer"
        "wang-xingxing ren-zhengfei zhang-yiming lei-jun li-yanhong li-kaifu liang-wenfeng yang-zhilin kaiming-he ma-huateng wang-jian lu-qi goodfellow schmidhuber dean chollet silver carmack torvalds wolfram"
    )
    _LABELS=("小动物" "编程语言" "美食" "太空" "神话生物" "音乐风格" "AI 大佬" "三体" "科技先锋")

    [ "$_NUM" -lt 1 ] && _NUM=1
    [ "$_NUM" -gt 20 ] && _NUM=20

    LABEL="${_LABELS[$_THEME_IDX]}"
    ALL_NAMES=$(echo "${_THEMES[$_THEME_IDX]}" | tr ' ' '\n' | sort -R | head -n $((_NUM + 1)) | tr '\n' ' ' | sed 's/ $//')
    ME=$(echo "$ALL_NAMES" | cut -d' ' -f1)
    WORKERS=$(echo "$ALL_NAMES" | cut -d' ' -f2-)

    printf "${D}初始化 .cnb/ ...${N}\n"
    "$CLAUDES_HOME/bin/init" $ALL_NAMES >/dev/null 2>&1
    "$CLAUDES_HOME/bin/swarm" start $WORKERS >/dev/null 2>&1 &
    disown
    _start_dispatcher
fi

# ---- Slash commands (runtime, gitignored) ----
CMD_DIR=".claude/commands"
mkdir -p "$CMD_DIR"
grep -qx 'commands/cnb-*' .claude/.gitignore 2>/dev/null || echo 'commands/cnb-*' >> .claude/.gitignore 2>/dev/null || true
BOARD="$CLAUDES_HOME/bin/board"
_PREFIX=$(grep '^prefix' "$_CFG_DIR/config.toml" 2>/dev/null | cut -d'"' -f2)
cat > "$CMD_DIR/cnb-watch.md"     <<EOF
看某个同学在干什么。解析 \$ARGUMENTS 拿到名字。
运行 \`tmux capture-pane -t ${_PREFIX}-<名字> -p -S -30 2>/dev/null | tail -20\`，用简洁的话告诉用户这个同学在做什么、进展到哪了。
EOF
cat > "$CMD_DIR/cnb-overview.md"  <<EOF
团队总览。对每个同学运行 \`tmux capture-pane -t ${_PREFIX}-<名字> -p -S -10 2>/dev/null | tail -5\`，汇总成一个简洁的表格告诉用户：谁在干什么、谁卡了、谁闲着。
同学列表：${WORKERS}
EOF
cat > "$CMD_DIR/cnb-progress.md"  <<EOF
运行 \`${BOARD} --as ${ME} inbox\` 和 \`${BOARD} --as ${ME} view\`，汇总最近的进展：谁完成了什么、有什么新消息、当前整体进度如何。用简洁的话告诉用户。
EOF
cat > "$CMD_DIR/cnb-history.md"   <<EOF
运行 \`${BOARD} --as ${ME} log 50\`，把完整的消息历史展示给我。
EOF
cat > "$CMD_DIR/cnb-pending.md"   <<EOF
查看需要用户介入的待处理操作。运行 \`${BOARD} --as ${ME} pending list\`，把所有 \`用户需执行: ! ...\` 命令整理成可复制清单；如果用户说已经执行，运行 \`${BOARD} --as ${ME} pending verify --retry\` 并汇报验证/重试结果。
EOF
cat > "$CMD_DIR/cnb-model.md"     <<'EOF'
---
allowed-tools: Bash(cnb model), Bash(cnb model *), Bash(cnb m), Bash(cnb m *)
argument-hint: "<profile> | list | current"
description: Switch cnb LLM provider (e.g. /cnb-model d for deepseek)
---

!`cnb m $ARGUMENTS`

Reply with only the command output above. Do not explain it unless the user asks.
EOF
cat > "$CMD_DIR/cnb-model-current.md" <<EOF
---
allowed-tools: Bash(cnb model current)
description: Show current cnb LLM provider/model profile
---

!\`cnb model current\`

Reply with only the command output above.
EOF
cat > "$CMD_DIR/cnb-model-list.md" <<EOF
---
allowed-tools: Bash(cnb model list)
description: List cnb LLM provider/model profiles
---

!\`cnb model list\`

Reply with only the command output above.
EOF
cat > "$CMD_DIR/cnb-update.md"    <<EOF
运行 \`npm install -g claude-nb\`，更新到最新版本。把结果告诉我，如果更新成功提醒用户重启 cnb 以生效。
EOF
cat > "$CMD_DIR/cnb-help.md"      <<EOF
列出所有 /cnb-* 命令：
- /cnb-overview — 团队总览：谁在干什么、谁卡了
- /cnb-watch <名字> — 看某个同学在干什么
- /cnb-progress — 最近进展汇总
- /cnb-history — 查看完整消息历史
- /cnb-pending — 查看待用户处理的操作并验证重试
- /cnb-model [menu|list|current|use profile] — 模型/provider 菜单或切换
- /cnb-model-current — 查看当前模型/provider
- /cnb-model-list — 列出可用模型/provider profiles
- /cnb-update — 更新 cnb 到最新版
EOF

# ---- Require interactive terminal ----
if [ ! -t 0 ] || [ ! -t 1 ]; then
    echo "错误: cnb 需要交互式终端运行。" >&2
    echo "用法: cnb [数量] [主题] [claude|codex]  （详见 cnb help）" >&2
    exit 1
fi

# ---- Banner + launch ----
clear
_check_update
printf "${B}${G}◆ cnb${N} ${D}v${VERSION}${N}\n"
printf "${D}  「${LABEL}」engine: ${_LEAD_AGENT}，你是 ${ME}，同学: ${WORKERS}${N}\n\n"

if [ "$_LEAD_AGENT" = "claude" ]; then
    _MONITOR_GUIDE="派任务给同学后，你必须主动跟进，不要派完就忘。使用 Monitor 工具挂一个后台轮询：
  Monitor 命令示例（每 30 秒检查一次 inbox，有新消息就通知你）：
    last_count=0; while true; do out=\$(${BOARD} --as ${ME} inbox 2>&1); count=\$(echo \"\$out\" | grep -c '<message'); if [ \"\$count\" -gt \"\$last_count\" ]; then echo \"\$out\"; last_count=\$count; fi; sleep 30; done
  设置 persistent: true，这样整个会话期间都会监控。"
else
    _MONITOR_GUIDE="派任务给同学后，你必须主动跟进，不要派完就忘。Codex 没有 Claude 的 Monitor 工具时，定期直接运行：
    ${BOARD} --as ${ME} inbox
  看到新消息后立刻汇总进展给用户。"
fi

SYSPROMPT="你是 ${ME}。你的终端直接面对用户。
你有 ${_NUM} 位同学在后台工作：${WORKERS}。你们是平等的，只是你负责和用户沟通。

管理团队的命令（直接在 Bash 里跑）：
  ${BOARD} --as ${ME} send <name> \"<任务描述>\"   # 给同学派任务
  ${BOARD} --as ${ME} send all \"<消息>\"          # 广播
  ${BOARD} --as ${ME} inbox                       # 查看回复
  ${BOARD} --as ${ME} view                        # 看所有人状态

工作方式：
- 用户说想做什么，你拆任务分给同学，自己也干活。
- 不要让用户跑命令。你直接用上面的命令操作。
- 同学之间可以互相 send 消息协作，不用什么都通过你。
- 用户可以用 /cnb-help 查看所有协作命令。

重要 — 监控团队进展：
${_MONITOR_GUIDE}
收到通知后汇总进展给用户。派完任务后应立刻启动监控。"

case "$_LEAD_AGENT" in
    claude)
        exec claude --name "${ME}" --append-system-prompt "$SYSPROMPT" ;;
    codex)
        codex features enable goals >/dev/null 2>&1 || true
        exec codex --dangerously-bypass-approvals-and-sandbox --cd "$CNB_PROJECT" "$SYSPROMPT" ;;
esac
