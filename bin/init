#!/usr/bin/env python3
"""cnb init — initialize a project for multi-agent coordination."""

import hashlib
import json
import re
import sqlite3
import sys
from pathlib import Path

# Ensure lib/ is importable (needed for migration runner)
_script = Path(__file__).resolve()
CLAUDES_HOME = _script.parent.parent
if str(CLAUDES_HOME) not in sys.path:
    sys.path.insert(0, str(CLAUDES_HOME))

# ── Session name validation ──

VALID_NAME = re.compile(r"^[a-z0-9](?:[a-z0-9_-]{0,62}[a-z0-9])?$")
RESERVED_NAMES: frozenset[str] = frozenset({"all", "dispatcher", "system"})
MAX_NAME_LEN = 64


def _validate_name(name: str) -> str:
    """Validate and lowercase a session name. Raises SystemExit on invalid input."""
    clean = name.strip().lower()
    if not clean:
        print("ERROR: empty session name")
        raise SystemExit(1)
    if len(clean) > MAX_NAME_LEN:
        print(f"ERROR: session name too long (max {MAX_NAME_LEN} chars): {name}")
        raise SystemExit(1)
    if clean in RESERVED_NAMES:
        print(f"ERROR: '{clean}' is a reserved name. Choose another.")
        raise SystemExit(1)
    if not VALID_NAME.match(clean):
        print(f"ERROR: invalid session name '{name}'. Use a-z, 0-9, hyphens, underscores.")
        print("       Example: cnb init alice bob charlie")
        raise SystemExit(1)
    return clean


MARKER_START = "<!-- cnb:start -->"
MARKER_END = "<!-- cnb:end -->"
PROJECT_MARKER_START = "<!-- cnb-project:start -->"
PROJECT_MARKER_END = "<!-- cnb-project:end -->"


def _claude_md_snippet(sessions: list[str], claudes_home: Path, personas: dict[str, str] | None = None) -> str:
    board = f"{claudes_home}/bin/board"
    lines = [
        MARKER_START,
        "## Multi-Agent Coordination",
        "",
        "This project uses cnb for multi-session coordination.",
        "",
        "### Session Startup",
        "",
        "You are a session. Your name is passed via `--name` when Claude Code starts.",
        "On startup:",
        "```bash",
        f"{board} --as <your-name> inbox",
        "```",
        "",
        "### Commands",
        "",
        "```bash",
        f'{board} --as <name> send <to> "<msg>"    # message (person or "all")',
        f"{board} --as <name> inbox                # check unread",
        f"{board} --as <name> ack                  # clear inbox",
        f'{board} --as <name> status "<desc>"      # update current task',
        f'{board} --as <name> task add "<desc>"    # add task',
        f"{board} --as <name> task done            # finish current task",
        f"{board} --as <name> view                 # board overview",
        f'{board} --as <name> bug report P1 "desc" # report bug',
        f'{board} --as <name> send all "msg"       # broadcast',
        "```",
        "",
        "### Rules",
        "",
        "- Check inbox at startup and after completing each task.",
        "- Update status when you start or finish work.",
        "- Commit immediately after each logical change.",
        "- Message others via `send`, not by editing their files.",
        "",
        "### Sessions",
        "",
    ]
    for s in sessions:
        p = (personas or {}).get(s, "")
        if p:
            lines.append(f"- **{s}** — {p.splitlines()[0]}")
        else:
            lines.append(f"- **{s}**")
    lines.append(MARKER_END)
    return "\n".join(lines) + "\n"


def _update_marked_md(
    md_path: Path, snippet: str, marker_start: str = MARKER_START, marker_end: str = MARKER_END
) -> None:
    if md_path.exists():
        text = md_path.read_text()
        if marker_start in text:
            import re

            text = re.sub(
                rf"{re.escape(marker_start)}.*?{re.escape(marker_end)}\n?",
                snippet,
                text,
                flags=re.DOTALL,
            )
        else:
            text = text.rstrip("\n") + "\n\n" + snippet
        md_path.write_text(text)
    else:
        md_path.write_text(snippet)


def _update_claude_md(project_dir: Path, snippet: str) -> None:
    _update_marked_md(project_dir / "CLAUDE.md", snippet)


def _update_agents_md(project_dir: Path, snippet: str) -> None:
    _update_marked_md(project_dir / "AGENTS.md", snippet)


def _project_marker_snippet(config_dir_name: str, prefix: str) -> str:
    return "\n".join(
        [
            PROJECT_MARKER_START,
            "# CNB Project",
            "",
            "This directory is managed by cnb.",
            "",
            "Do not delete it just because it looks empty in Finder or with plain `ls`.",
            f"Project state lives in `{config_dir_name}/`, including the SQLite board, sessions, logs, and keys.",
            f"Project prefix: `{prefix}`.",
            "",
            "Useful commands:",
            "",
            "```bash",
            "cnb status",
            "cnb board --as <name> inbox",
            "cnb board --as <name> view",
            "```",
            PROJECT_MARKER_END,
            "",
        ]
    )


def _update_project_marker(project_dir: Path, config_dir_name: str, prefix: str) -> None:
    _update_marked_md(
        project_dir / "CNB.md",
        _project_marker_snippet(config_dir_name, prefix),
        PROJECT_MARKER_START,
        PROJECT_MARKER_END,
    )


def _hook_command(claudes_home: Path) -> str:
    return (
        'if [ -n "$CLAUDE_SESSION_NAME" ] && [ -n "$CNB_PROJECT" ]; then '
        'CFG="$CNB_PROJECT/.cnb/config.toml"; [ ! -f "$CFG" ] && CFG="$CNB_PROJECT/.claudes/config.toml"; '
        "BOARD=$(grep '^claudes_home' \"$CFG\" 2>/dev/null "
        "| cut -d'\"' -f2)/bin/board; "
        '[ -x "$BOARD" ] && $BOARD --as $CLAUDE_SESSION_NAME pulse 2>/dev/null; fi'
    )


def _update_settings(project_dir: Path, claudes_home: Path) -> None:
    settings_dir = project_dir / ".claude"
    settings_dir.mkdir(exist_ok=True)
    settings_path = settings_dir / "settings.json"

    hook_entry = {
        "matcher": "",
        "hooks": [{"type": "command", "command": _hook_command(claudes_home)}],
    }

    if settings_path.exists():
        try:
            settings = json.loads(settings_path.read_text())
        except (json.JSONDecodeError, ValueError):
            settings = {}
    else:
        settings = {}

    hooks = settings.setdefault("hooks", {})
    post_batch = hooks.setdefault("PostToolBatch", [])

    already = any(
        isinstance(h, dict)
        and any(
            "board" in sub.get("command", "")
            and ("pulse" in sub.get("command", "") or "inbox" in sub.get("command", ""))
            for sub in h.get("hooks", [])
            if isinstance(sub, dict)
        )
        for h in post_batch
    )
    if not already:
        post_batch.append(hook_entry)

    settings_path.write_text(json.dumps(settings, indent=2, ensure_ascii=False) + "\n")


def _install_pre_commit_hook(project_dir: Path, claudes_home: Path) -> None:
    """Install bin/secret-scan as a git pre-commit hook if git repo exists."""
    git_dir = project_dir / ".git"
    if not git_dir.is_dir():
        return
    hooks_dir = git_dir / "hooks"
    hooks_dir.mkdir(exist_ok=True)
    hook_path = hooks_dir / "pre-commit"
    secret_scan = claudes_home / "bin" / "secret-scan"
    if not secret_scan.exists():
        return
    if hook_path.exists():
        content = hook_path.read_text()
        if "secret-scan" in content:
            return
        content = content.rstrip("\n") + f"\n\n# cnb: block sensitive files\n{secret_scan}\n"
        hook_path.write_text(content)
    else:
        hook_path.write_text(f"#!/bin/sh\n{secret_scan}\n")
    hook_path.chmod(0o755)


DEFAULT_SESSIONS = ["s1", "s2", "s3"]


def _load_team_toml(path: Path) -> tuple[list[str], dict[str, str]]:
    """Load a team definition TOML file. Returns (session_names, {name: persona})."""
    import tomllib

    data = tomllib.loads(path.read_text())
    personas: dict[str, str] = {}
    sessions: list[str] = []
    for name, info in data.get("session", {}).items():
        clean = _validate_name(name)
        sessions.append(clean)
        if isinstance(info, dict) and info.get("persona"):
            personas[clean] = info["persona"]
    return sessions, personas


def main() -> None:
    raw_sessions: list[str] = sys.argv[1:]

    team_file: Path | None = None
    personas: dict[str, str] = {}

    # Check for --team flag
    if "--team" in raw_sessions:
        idx = raw_sessions.index("--team")
        if idx + 1 < len(raw_sessions):
            team_file = Path(raw_sessions[idx + 1])
            if not team_file.exists():
                print(f"ERROR: team file not found: {team_file}")
                raise SystemExit(1)
            raw_sessions = raw_sessions[:idx] + raw_sessions[idx + 2 :]
        else:
            print("ERROR: --team requires a path")
            raise SystemExit(1)

    if team_file:
        sessions, personas = _load_team_toml(team_file)
    elif raw_sessions:
        sessions = [_validate_name(s) for s in raw_sessions]
    else:
        sessions = list(DEFAULT_SESSIONS)
    project_dir = Path.cwd()
    claudes_dir = project_dir / ".cnb"
    claudes_home = CLAUDES_HOME

    # Also accept existing .claudes/ projects
    legacy_dir = project_dir / ".claudes"
    if not claudes_dir.exists() and legacy_dir.exists():
        claudes_dir = legacy_dir

    if (claudes_dir / "board.db").exists():
        print(f"Already initialized: {claudes_dir}")
        sys.exit(0)

    # Create directory structure
    for subdir in ("sessions", "files", "okr", "cv", "logs"):
        (claudes_dir / subdir).mkdir(parents=True, exist_ok=True)

    # Generate short unique prefix from project path
    project_hash = hashlib.sha256(str(project_dir).encode()).hexdigest()[:4]
    prefix = f"cc-{project_hash}"

    # Generate config.toml
    sessions_toml = ", ".join(f'"{s}"' for s in sessions)
    toml_lines = [
        f'claudes_home = "{claudes_home}"',
        f"sessions = [{sessions_toml}]",
        f'prefix = "{prefix}"',
        "",
    ]
    for s in sessions:
        toml_lines.append(f"[session.{s}]")
        p = personas.get(s, "")
        toml_lines.append(f'persona = """{p}"""' if "\n" in p else f'persona = "{p}"')
        toml_lines.append("")
    (claudes_dir / "config.toml").write_text("\n".join(toml_lines) + "\n")

    # Initialize SQLite database from schema.sql
    schema_file = claudes_home / "schema.sql"
    db_path = claudes_dir / "board.db"
    conn = sqlite3.connect(str(db_path))
    conn.execute("PRAGMA journal_mode=WAL;")
    conn.execute("PRAGMA foreign_keys=ON;")
    conn.executescript(schema_file.read_text())
    # Insert sessions + pseudo-session 'all' for broadcast FK references
    conn.execute("INSERT OR IGNORE INTO sessions(name, status) VALUES ('all', 'system')")
    for name in sessions:
        n = name.lower()
        persona = personas.get(n, "")
        conn.execute("INSERT OR IGNORE INTO sessions(name, persona) VALUES (?, ?)", (n, persona))
        persona_section = f"\n## Persona\n{persona}\n" if persona else ""
        md_content = f"# {n}\n{persona_section}\n## Current task\n(none)\n"
        (claudes_dir / "sessions" / f"{n}.md").write_text(md_content)
    conn.execute("INSERT OR IGNORE INTO meta(key, value) VALUES ('dispatcher_session', 'dispatcher')")
    from lib.migrate import latest_migration_version, run_migrations

    schema_version = str(latest_migration_version(claudes_home))
    conn.execute(
        "INSERT OR IGNORE INTO meta(key, value) VALUES ('schema_version', ?)",
        (schema_version,),
    )
    conn.commit()
    conn.close()

    # Run any pending migrations (idempotent)
    applied = run_migrations(db_path, claudes_home)
    if applied:
        print(f"Applied {applied} schema migration(s).")

    # .gitignore for generated stuff
    gitignore_content = "board.db\nboard.db-shm\nboard.db-wal\nlogs/\ndispatcher.pid\nkeys/\n"
    (claudes_dir / ".gitignore").write_text(gitignore_content)

    # Visible marker so a cnb-only project does not look empty in Finder or plain ls.
    _update_project_marker(project_dir, claudes_dir.name, prefix)

    # Install pre-commit hook for secret scanning
    _install_pre_commit_hook(project_dir, claudes_home)

    # Update .claude/settings.json (merge hooks if exists, create if not)
    _update_settings(project_dir, claudes_home)

    # Write multi-agent coordination sections for Claude Code and Codex.
    snippet = _claude_md_snippet(sessions, claudes_home, personas)
    _update_claude_md(project_dir, snippet)
    _update_agents_md(project_dir, snippet)

    # Register in global project registry
    try:
        from lib.global_registry import register_project

        register_project(project_dir, project_dir.name)
    except Exception:
        pass  # non-fatal — registry is optional

    # Generate encryption keypairs for all sessions (Issue #22)
    try:
        from lib.board_mailbox import _load_pubkeys, _save_pubkeys
        from lib.crypto import generate_keypair, key_storage_name, public_key_to_hex, save_keypair

        keys_dir = claudes_dir / "keys"
        pubkeys = _load_pubkeys()
        gen_count = 0
        for s in sessions:
            n = s.lower()
            namespaced_key = keys_dir / f"{key_storage_name(n, project_dir)}.pem"
            legacy_key = keys_dir / f"{key_storage_name(n)}.pem"
            if namespaced_key.exists() or legacy_key.exists():
                continue
            private, public = generate_keypair()
            save_keypair(keys_dir, n, private, public, project_dir)
            pubkeys[n] = public_key_to_hex(public)
            gen_count += 1
        if gen_count:
            _save_pubkeys(pubkeys)
            print(f"Generated {gen_count} encryption keypair(s).")
    except ImportError:
        pass  # cryptography not installed — skip keygen

    sessions_str = " ".join(sessions)
    print(f"Initialized cnb (sessions: {sessions_str})")


if __name__ == "__main__":
    main()
