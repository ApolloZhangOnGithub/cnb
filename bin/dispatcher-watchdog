#!/usr/bin/env python3
"""dispatcher-watchdog — Keeps dispatcher running, restarts on crash.

Usage: nohup ./dispatcher-watchdog > /tmp/dispatcher.log 2>&1 &
"""

import os
import subprocess
import sys
import time
from datetime import datetime
from pathlib import Path

# Resolve CLAUDES_HOME
_self = Path(__file__).resolve()
CLAUDES_HOME = _self.parent.parent

DISPATCHER = str(CLAUDES_HOME / "bin" / "dispatcher")
MAX_RESTARTS = 50
COOLDOWN = 5
CRASH_WINDOW = 60
LOG_TAG = "[watchdog]"


def log(msg: str) -> None:
    ts = datetime.now().strftime("%H:%M:%S")
    print(f"{LOG_TAG} {ts} {msg}", flush=True)


def main() -> None:
    restart_count = 0
    last_crash = 0.0

    log(f"Starting watchdog for dispatcher (max restarts: {MAX_RESTARTS})")

    while True:
        log(f"Launching dispatcher (restart #{restart_count})")
        result = subprocess.run(["bash", DISPATCHER])
        exit_code = result.returncode
        now = time.time()

        log(f"dispatcher exited with code {exit_code}")

        if (now - last_crash) < CRASH_WINDOW:
            restart_count += 1
            if restart_count >= MAX_RESTARTS:
                log(
                    f"FATAL: {MAX_RESTARTS} rapid restarts within "
                    f"{CRASH_WINDOW}s window. Giving up."
                )
                sys.exit(1)
            log(
                f"Rapid restart detected (#{restart_count}/{MAX_RESTARTS}), "
                f"cooling down {COOLDOWN}s..."
            )
            time.sleep(COOLDOWN)
        else:
            restart_count = 0

        last_crash = now


if __name__ == "__main__":
    main()
