#!/usr/bin/env python3
"""secret-scan — pre-commit hook to block sensitive files from being committed.

Checks staged files against known sensitive filename patterns and scans
content for common secret patterns (API keys, private keys, tokens).

Usage:
    bin/secret-scan          # scan staged files (pre-commit mode)
    bin/secret-scan --all    # scan entire working tree
"""

import subprocess
import sys
from pathlib import Path

CLAUDES_HOME = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(CLAUDES_HOME))

from lib import secret_scan_core as _core

GENERIC_SECRET_ASSIGNMENT = _core.GENERIC_SECRET_ASSIGNMENT
SENSITIVE_CONTENT = _core.SENSITIVE_CONTENT
SENSITIVE_FILENAMES = _core.SENSITIVE_FILENAMES
SKIP_EXTENSIONS = _core.SKIP_EXTENSIONS
SKIP_PATHS = _core.SKIP_PATHS
_looks_like_secret_literal = _core.looks_like_secret_literal
_scan_content = _core.scan_content
_scan_filename = _core.scan_filename
_should_skip = _core.should_skip


def _get_staged_files() -> list[str]:
    r = subprocess.run(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=ACMR"],
        capture_output=True,
        text=True,
        timeout=10,
    )
    return [f for f in r.stdout.strip().splitlines() if f]


def _get_all_tracked_files() -> list[str]:
    r = subprocess.run(
        ["git", "ls-files"],
        capture_output=True,
        text=True,
        timeout=10,
    )
    return [f for f in r.stdout.strip().splitlines() if f]


def main() -> int:
    scan_all = "--all" in sys.argv

    if scan_all:
        files = _get_all_tracked_files()
        mode = "working tree"
    else:
        files = _get_staged_files()
        mode = "staged files"

    if not files:
        return 0

    blocked = []

    for filepath in files:
        if _should_skip(filepath):
            continue

        name_issue = _scan_filename(filepath)
        if name_issue:
            blocked.append((filepath, 0, name_issue))
            continue

        content_issues = _scan_content(filepath)
        for lineno, label in content_issues:
            blocked.append((filepath, lineno, label))

    if blocked:
        print(f"SECRET-SCAN: {len(blocked)} potential secret(s) found in {mode}:\n")
        for filepath, lineno, issue in blocked:
            loc = f":{lineno}" if lineno else ""
            print(f"  BLOCKED: {filepath}{loc} — {issue}")
        print(
            "\nIf this is a false positive, add the file to SKIP_PATHS in bin/secret-scan."
            "\nTo bypass (emergency only): git commit --no-verify"
        )
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
