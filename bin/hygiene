#!/usr/bin/env python3
"""Report generated files, local runtime state, and suspicious untracked work."""

from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path

GENERATED_DIR_NAMES = {
    "__pycache__",
    ".build",
    ".mypy_cache",
    ".pytest_cache",
    ".ruff_cache",
    ".venv",
    "build",
    "dist",
    "DerivedData",
}

LOCAL_STATE_PREFIXES = (
    ".cnb/",
    ".claudes/",
    ".claude/commands/",
    ".claude/settings.local.json",
    ".claude/worktrees/",
    "instances/",
    "npm_recovery_codes.txt",
)

MARKED_BACKUP_TOKENS = (".shit", " 2")


def _git(args: list[str]) -> list[str]:
    result = subprocess.run(
        ["git", *args],
        capture_output=True,
        check=True,
        text=True,
        timeout=20,
    )
    return [line for line in result.stdout.splitlines() if line]


def _git_root() -> Path:
    try:
        return Path(_git(["rev-parse", "--show-toplevel"])[0])
    except (subprocess.CalledProcessError, IndexError):
        print("ERROR: cnb hygiene must run inside a git repository", file=sys.stderr)
        raise SystemExit(2)


def _size(root: Path, files: list[str]) -> int:
    total = 0
    for relpath in files:
        try:
            total += (root / relpath).lstat().st_size
        except OSError:
            pass
    return total


def _human_size(size: int) -> str:
    value = float(size)
    for unit in ("B", "K", "M", "G", "T"):
        if value < 1024 or unit == "T":
            if unit == "B":
                return f"{int(value)}B"
            return f"{value:.1f}{unit}"
        value /= 1024
    return f"{size}B"


def _is_generated(relpath: str) -> bool:
    path = Path(relpath)
    if path.name == ".DS_Store" or path.suffix == ".pyc":
        return True
    if any(part in GENERATED_DIR_NAMES for part in path.parts):
        return True
    return any(part.endswith(".egg-info") for part in path.parts)


def _is_local_state(relpath: str) -> bool:
    return any(relpath == prefix.rstrip("/") or relpath.startswith(prefix) for prefix in LOCAL_STATE_PREFIXES)


def _is_marked_backup(relpath: str) -> bool:
    return any(token in relpath for token in MARKED_BACKUP_TOKENS)


def _top_dirs(files: list[str], *, limit: int = 8) -> list[tuple[str, int]]:
    counts: dict[str, int] = {}
    for relpath in files:
        key = relpath.split("/", 1)[0]
        counts[key] = counts.get(key, 0) + 1
    return sorted(counts.items(), key=lambda item: (-item[1], item[0]))[:limit]


def _summary(root: Path) -> dict[str, object]:
    ignored = _git(["ls-files", "--others", "--ignored", "--exclude-standard"])
    untracked = _git(["ls-files", "--others", "--exclude-standard"])
    deleted = _git(["diff", "--name-only", "--diff-filter=D"])
    modified = _git(["diff", "--name-only", "--diff-filter=M"])

    generated = [path for path in ignored if _is_generated(path)]
    local_state = [path for path in ignored if _is_local_state(path) and not _is_generated(path)]
    generated_set = set(generated)
    local_state_set = set(local_state)
    other_ignored = [path for path in ignored if path not in generated_set and path not in local_state_set]
    marked_backups = [path for path in untracked if _is_marked_backup(path)]
    marked_backup_set = set(marked_backups)
    untracked_other = [path for path in untracked if path not in marked_backup_set]

    return {
        "generated": {
            "count": len(generated),
            "bytes": _size(root, generated),
            "top_dirs": _top_dirs(generated),
        },
        "local_state": {
            "count": len(local_state),
            "bytes": _size(root, local_state),
            "top_dirs": _top_dirs(local_state),
        },
        "other_ignored": {
            "count": len(other_ignored),
            "bytes": _size(root, other_ignored),
            "sample": other_ignored[:20],
        },
        "marked_backups": {
            "count": len(marked_backups),
            "bytes": _size(root, marked_backups),
            "sample": marked_backups[:40],
        },
        "untracked_other": {
            "count": len(untracked_other),
            "bytes": _size(root, untracked_other),
            "sample": untracked_other[:40],
        },
        "tracked_changes": {
            "modified": len(modified),
            "deleted": len(deleted),
            "deleted_sample": deleted[:40],
        },
    }


def _print_report(summary: dict[str, object]) -> None:
    generated = summary["generated"]
    local_state = summary["local_state"]
    marked = summary["marked_backups"]
    untracked = summary["untracked_other"]
    tracked = summary["tracked_changes"]

    assert isinstance(generated, dict)
    assert isinstance(local_state, dict)
    assert isinstance(marked, dict)
    assert isinstance(untracked, dict)
    assert isinstance(tracked, dict)

    print("cnb hygiene")
    print(f"  generated/cache: {generated['count']} files, {_human_size(int(generated['bytes']))}")
    for name, count in generated["top_dirs"]:
        print(f"    {name}: {count}")
    print(f"  local runtime state: {local_state['count']} files, {_human_size(int(local_state['bytes']))}")
    print(f"  marked backups / duplicates: {marked['count']} files, {_human_size(int(marked['bytes']))}")
    print(f"  other untracked work: {untracked['count']} files, {_human_size(int(untracked['bytes']))}")
    print(f"  tracked changes: {tracked['modified']} modified, {tracked['deleted']} deleted")

    if marked["sample"]:
        print("\nmarked backup sample:")
        for path in marked["sample"]:
            print(f"  {path}")
    if untracked["sample"]:
        print("\nother untracked sample:")
        for path in untracked["sample"]:
            print(f"  {path}")
    if tracked["deleted_sample"]:
        print("\ntracked deletions sample:")
        for path in tracked["deleted_sample"]:
            print(f"  {path}")

    print(
        "\nGuidance: generated/cache files are usually reproducible; local runtime state "
        "and tracked deletions need review before removal."
    )


def main(argv: list[str] | None = None) -> int:
    argv = list(sys.argv[1:] if argv is None else argv)
    root = _git_root()
    summary = _summary(root)
    if "--json" in argv:
        print(json.dumps(summary, ensure_ascii=False, sort_keys=True))
    else:
        _print_report(summary)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
