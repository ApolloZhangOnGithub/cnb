# Runtime
CNB_SYNC_HOST=0.0.0.0
CNB_SYNC_PORT=8765
CNB_SYNC_DATA_DIR=/var/lib/cnb-sync
CNB_SYNC_TOKEN=replace-with-a-long-random-token
CNB_SYNC_CORS_ORIGIN=*

# Encrypted Git backup.
# The server only needs the public GPG key for this recipient.
CNB_SYNC_BACKUP_GIT_REMOTE=git@github.com:your-org/cnb-sync-backups.git
CNB_SYNC_BACKUP_REPO=/var/backups/cnb-sync-git
CNB_SYNC_BACKUP_BRANCH=main
CNB_SYNC_BACKUP_GPG_RECIPIENT=your-local-gpg-key-id-or-email
CNB_SYNC_BACKUP_KEEP=96
