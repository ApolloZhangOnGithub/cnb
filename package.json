{
  "name": "claude-nb",
  "version": "0.5.52-dev",
  "description": "Multi-agent coordination framework for Claude Code sessions",
  "engines": {
    "node": ">=18"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "bin": {
    "cnb": "bin/cnb.js"
  },
  "peerDependencies": {
    "@anthropic-ai/claude-code": "*",
    "@openai/codex": "*"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/claude-code": {
      "optional": true
    },
    "@openai/codex": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ApolloZhangOnGithub/cnb.git"
  },
  "homepage": "https://c-n-b.space",
  "bugs": {
    "url": "https://github.com/ApolloZhangOnGithub/cnb/issues"
  },
  "files": [
    "bin/",
    "!bin/__pycache__/",
    "lib/",
    "!lib/**/__pycache__/",
    "!**/*.pyc",
    "migrations/",
    "registry/",
    "schema.sql",
    "pyproject.toml",
    "VERSION",
    "Makefile"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "feishu",
    "lark",
    "multi-agent",
    "coordination",
    "local-first",
    "ai",
    "coding-agent",
    "developer-tools"
  ],
  "license": "MIT"
}
